# Local dev defaults. Copy to .env and fill in.

# Data root. On TrueNAS, set to /mnt/tank/grimoire.
DATA_ROOT=./data

# Crossref polite-pool email. Without it, rate limit is 5 req/s instead of 50.
GRIMOIRE_CROSSREF_MAILTO=

# LLM features activate automatically when this is set. Used for:
#  - ingest metadata fallback when no DOI/arXiv/ISBN is found (Phase 1)
#  - the dedup judge on ambiguous pairs (Phase 3)
# Ongoing cost expectation: cents per week; one-time migration ~$3.
GRIMOIRE_ANTHROPIC_API_KEY=
GRIMOIRE_LLM_MODEL=claude-sonnet-4-6
