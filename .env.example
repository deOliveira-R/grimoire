# Local dev defaults. Copy to .env and fill in.

# Data root. On TrueNAS, set to /mnt/tank/grimoire.
DATA_ROOT=./data

# Crossref polite-pool email. Without it, rate limit is 5 req/s instead of 50.
GRIMOIRE_CROSSREF_MAILTO=

# LLM judge for the ambiguous dedup band. Costs ~$0.01/call.
GRIMOIRE_LLM_JUDGE_ENABLED=false
ANTHROPIC_API_KEY=
